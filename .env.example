# Supabase Configuration (Add these after creating Supabase project)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Google OAuth (Add these after setting up Google OAuth credentials)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase service role key — SERVER ONLY, never exposed to the browser.
# Used by the notification API route to read every recipient's push
# subscription. Find it in Supabase → Project Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Web Push (VAPID) keys — generate once with:  npx web-push generate-vapid-keys
# The PUBLIC key is safe to expose; the PRIVATE key is server-only.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_CONTACT_EMAIL=mailto:you@example.com
